# Optional fallback. Prefer the refreshable Device Flow at http://localhost:8000/auth.
TOKEN=

PUBLIC_BASE_URL=http://localhost:8000
BIND_ADDRESS=127.0.0.1
PORT=8000
PUID=1000
PGID=1000

# Named volumes are the default. Absolute host paths also work here.
DATA_VOLUME=yandexmusic2feed-data
MEDIA_VOLUME=yandexmusic2feed-media

SCHEDULER_POLL_SECONDS=300
DOWNLOAD_BITRATE_KBPS=192
MIN_FREE_GB=10
YANDEX_DEVICE_NAME=YandexMusic2Feed

# Optional custom OAuth application credentials.
YANDEX_CLIENT_ID=
YANDEX_CLIENT_SECRET=

# Optional image override, for example ghcr.io/owner/yandexmusic2feed:latest.
YANDEXMUSIC2FEED_IMAGE=yandexmusic2feed:local
